@page
@model SynergySwitch.Api.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h4 class="mb-3">Switch Overview</h4>

@* ── Gateway Connection Status ── *@
@if (Model.GatewayStatuses.Count == 0)
{
    <div class="alert alert-warning mb-4">
        No gateways configured. <a asp-page="/Gateways/Index">Add a gateway</a> to start processing transactions.
    </div>
}
else
{
    <div class="row g-3 mb-4">
        @foreach (var gw in Model.GatewayStatuses)
        {
            var badgeClass = gw.ActiveConnections > 0 ? "bg-success" : "bg-danger";
            var borderClass = gw.ActiveConnections > 0 ? "border-success" : "border-danger";
            <div class="col-md-4">
                <div class="card @borderClass" style="border-width: 2px;">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <strong>@gw.GatewayName</strong>
                            <span class="badge @badgeClass">@(gw.ActiveConnections > 0 ? "Connected" : "Down")</span>
                        </div>
                        <small class="text-muted">@gw.Host:@gw.Port</small>
                        <div class="mt-1">
                            <small>Pool: <strong>@gw.ActiveConnections/@gw.PoolSize</strong></small>
                            @if (gw.PendingRequests > 0)
                            {
                                <small class="text-info ms-2">In-flight: <strong>@gw.PendingRequests</strong></small>
                            }
                            @if (gw.TotalDrops > 0)
                            {
                                <small class="text-warning ms-2">Drops: <strong>@gw.TotalDrops</strong></small>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card approved">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Approval Rate</h6>
                <h2 class="card-title">@Model.Summary.ApprovalRatePercent%</h2>
                <small class="text-muted">
                    @Model.Summary.ApprovedCount approved / @Model.Summary.TotalTransactions total
                </small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card declined">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Declined</h6>
                <h2 class="card-title">@Model.Summary.DeclinedCount</h2>
                <small class="text-muted">
                    Tech errors: @Model.Summary.TechnicalErrorCount
                </small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card performance">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Avg Response Time</h6>
                <h2 class="card-title">@Model.Summary.AverageResponseTimeMs ms</h2>
                <small class="text-muted">Bank responsiveness</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card terminals">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Terminals</h6>
                <h2 class="card-title">@Model.Summary.ActiveTerminals active</h2>
                <small class="text-muted">
                    @Model.Summary.InactiveTerminals inactive
                </small>
            </div>
        </div>
    </div>
</div>

<h5>Today (@DateTime.UtcNow.ToString("dd MMM yyyy") UTC)</h5>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h6>Transactions Today</h6>
                <h3>@Model.TodaySummary.TotalTransactions</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h6>Today Approval Rate</h6>
                <h3>@Model.TodaySummary.ApprovalRatePercent%</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h6>Volume Processed</h6>
                <h3 class="table-amount">
                    @((Model.TodaySummary.TotalAmountProcessed / 100m).ToString("N2"))
                    @Model.TodaySummary.Currency
                </h3>
            </div>
        </div>
    </div>
</div>

<h5>Hourly Throughput (Last 24h)</h5>
<div class="table-responsive">
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Hour (UTC)</th>
                <th class="text-end">Total</th>
                <th class="text-end">Approved</th>
                <th class="text-end">Declined</th>
                <th>Throughput</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.HourlyData.Count == 0)
            {
                <tr><td colspan="5" class="text-muted text-center">No transactions in the last 24 hours</td></tr>
            }
            @foreach (var h in Model.HourlyData)
            {
                var maxCount = Model.HourlyData.Max(x => x.Count);
                var barWidth = maxCount > 0 ? (int)(h.Count * 100.0 / maxCount) : 0;
                <tr>
                    <td>@h.Hour.ToString("HH:mm")</td>
                    <td class="text-end">@h.Count</td>
                    <td class="text-end">@h.ApprovedCount</td>
                    <td class="text-end">@h.DeclinedCount</td>
                    <td>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar bg-success" style="width: @barWidth%"></div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
