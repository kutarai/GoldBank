@page
@model SynergySwitch.Api.Pages.Terminals.IndexModel
@{
    ViewData["Title"] = "Terminals";
}

<h4 class="mb-3">Terminal Fleet</h4>

<p class="text-muted">
    @Model.Terminals.Count(t => t.Status == "Online") online,
    @Model.Terminals.Count(t => t.Status == "Stale") stale,
    @Model.Terminals.Count(t => t.Status == "Offline") offline
    &mdash; @Model.Terminals.Count total
</p>

<div class="table-responsive">
    <table class="table table-sm table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Terminal ID</th>
                <th>Merchant</th>
                <th>Status</th>
                <th>Last Heartbeat</th>
                <th>Battery</th>
                <th class="text-end">Txn Count</th>
                <th>Serial</th>
                <th>Firmware</th>
                <th>App</th>
                <th>Registered</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Terminals.Count == 0)
            {
                <tr><td colspan="10" class="text-muted text-center">No terminals registered</td></tr>
            }
            @foreach (var t in Model.Terminals)
            {
                var statusBadge = t.Status switch
                {
                    "Online" => "bg-success",
                    "Stale" => "bg-warning text-dark",
                    _ => "bg-secondary"
                };
                var batteryClass = t.BatteryLevel switch
                {
                    <= 20 => "text-danger fw-bold",
                    <= 50 => "text-warning",
                    _ => (string?)null
                };
                <tr>
                    <td><strong>@t.TerminalId</strong></td>
                    <td>@t.MerchantId</td>
                    <td><span class="badge @statusBadge">@t.Status</span></td>
                    <td>@t.LastHeartbeat.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td class="@batteryClass">@t.BatteryLevel%</td>
                    <td class="text-end">@t.TransactionCount.ToString("N0")</td>
                    <td>@(t.SerialNumber ?? "-")</td>
                    <td>@(t.FirmwareVersion ?? "-")</td>
                    <td>@(t.AppVersion ?? "-")</td>
                    <td>@t.RegisteredAt.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
