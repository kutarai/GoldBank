<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - SynergySwitch</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <style>
        .badge-approved { background-color: #198754; }
        .badge-declined { background-color: #dc3545; }
        .badge-error { background-color: #6c757d; }
        .stat-card { border-left: 4px solid; }
        .stat-card.approved { border-left-color: #198754; }
        .stat-card.declined { border-left-color: #dc3545; }
        .stat-card.terminals { border-left-color: #0d6efd; }
        .stat-card.performance { border-left-color: #ffc107; }
        .table-amount { font-family: monospace; text-align: right; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-page="/Dashboard/Index">SynergySwitch</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-page="/Dashboard/Index">Dashboard</a>
                <a class="nav-link" asp-page="/Transactions/Index">Transactions</a>
                <a class="nav-link" asp-page="/Terminals/Index">Terminals</a>
                <a class="nav-link" asp-page="/Gateways/Index">Gateways</a>
            </div>
        </div>
    </nav>
    <div class="container-fluid mt-3">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
