# ── Build stage ──
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy project files first for layer caching
COPY src/SynergySwitch.Data/SynergySwitch.Data.csproj src/SynergySwitch.Data/
COPY src/SynergySwitch.Core/SynergySwitch.Core.csproj src/SynergySwitch.Core/
COPY src/SynergySwitch.Api/SynergySwitch.Api.csproj src/SynergySwitch.Api/
COPY protos/ protos/

RUN dotnet restore src/SynergySwitch.Api/SynergySwitch.Api.csproj

# Copy all source
COPY src/ src/

RUN dotnet publish src/SynergySwitch.Api/SynergySwitch.Api.csproj \
    -c Release -o /app

# ── Runtime stage ──
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

COPY --from=build /app .

# gRPC port + Web/Metrics port
EXPOSE 3333 8080

ENV ASPNETCORE_ENVIRONMENT=Production

ENTRYPOINT ["dotnet", "SynergySwitch.Api.dll"]
