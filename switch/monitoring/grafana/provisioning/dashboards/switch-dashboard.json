{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Transaction Rate (per second)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(switch_transactions_total[5m])",
          "legendFormat": "{{response_code}} / {{entry_mode}}"
        }
      ]
    },
    {
      "title": "Transaction Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(switch_transaction_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(switch_transaction_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(switch_transaction_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Bank Round-Trip Duration (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(switch_bank_response_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(switch_bank_response_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "title": "Total Transactions by Response",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(switch_transactions_total) by (response_code)",
          "legendFormat": "{{response_code}}"
        }
      ]
    },
    {
      "title": "Active Bank Connections",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "switch_bank_connections_active",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "title": "Connection Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 8 },
      "targets": [
        {
          "expr": "sum(switch_bank_connection_errors_total)",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "title": "ISO 8583 Messages Sent/Received",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(switch_iso8583_messages_sent_total[5m])",
          "legendFormat": "Sent {{message_type}}"
        },
        {
          "expr": "rate(switch_iso8583_messages_received_total[5m])",
          "legendFormat": "Received {{message_type}}"
        }
      ]
    },
    {
      "title": "ISO 20022 Messages Sent/Received",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(switch_iso20022_messages_sent_total[5m])",
          "legendFormat": "Sent: {{gateway_name}} {{method}}"
        },
        {
          "expr": "rate(switch_iso20022_messages_received_total[5m])",
          "legendFormat": "Received: {{gateway_name}} ({{response_code}})"
        }
      ]
    },
    {
      "title": "Transactions by Currency",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(switch_transactions_total) by (currency)",
          "legendFormat": "{{currency}}"
        }
      ]
    },
    {
      "title": "Gateway Connectivity State",
      "description": "1 = Ready, 0.5 = Connecting, 0 = Down. Alerts fire when a gateway stays at 0.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "switch_gateway_connectivity_state",
          "legendFormat": "{{gateway_name}} ({{protocol}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 1 }
            ]
          },
          "custom": { "fillOpacity": 30, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "State Transitions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "targets": [
        {
          "expr": "rate(switch_gateway_state_transitions_total[5m])",
          "legendFormat": "{{gateway_name}}: {{from_state}} → {{to_state}}"
        }
      ]
    },
    {
      "title": "Connection Drops Detected (alertable)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "rate(switch_gateway_connection_drops_detected_total[5m])",
          "legendFormat": "Drops: {{gateway_name}} ({{protocol}})"
        },
        {
          "expr": "rate(switch_gateway_reconnects_detected_total[5m])",
          "legendFormat": "Reconnects: {{gateway_name}} ({{protocol}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Prometheus Alerts",
      "type": "alertlist",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "options": {
        "showOptions": "current",
        "sortOrder": 1,
        "alertName": "",
        "dashboardAlerts": false,
        "stateFilter": { "firing": true, "pending": true, "noData": false, "normal": false }
      }
    },
    {
      "title": "Gateway Pool — Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "switch_gateway_pool_active_connections",
          "legendFormat": "{{gateway_name}} ({{gateway_host}})"
        },
        {
          "expr": "switch_gateway_pool_size",
          "legendFormat": "{{gateway_name}} pool size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Gateway — In-Flight Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "switch_gateway_pending_requests",
          "legendFormat": "{{gateway_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Gateway Round-Trip (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(switch_gateway_roundtrip_seconds_bucket[5m]))",
          "legendFormat": "{{gateway_name}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(switch_gateway_roundtrip_seconds_bucket[5m]))",
          "legendFormat": "{{gateway_name}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Gateway Transactions Routed (rate/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "rate(switch_gateway_transactions_routed_total[5m])",
          "legendFormat": "{{gateway_name}} — {{response_code}}"
        }
      ]
    },
    {
      "title": "Gateway Connection Drops & Reconnects",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "rate(switch_gateway_connection_drops_total[5m])",
          "legendFormat": "Drops: {{gateway_name}}"
        },
        {
          "expr": "rate(switch_gateway_reconnect_attempts_total[5m])",
          "legendFormat": "Reconnects: {{gateway_name}}"
        }
      ]
    },
    {
      "title": "ThreadPool — Available Workers & I/O Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "targets": [
        {
          "expr": "switch_threadpool_worker_threads_available",
          "legendFormat": "Worker threads available"
        },
        {
          "expr": "switch_threadpool_completion_port_threads_available",
          "legendFormat": "I/O threads available"
        },
        {
          "expr": "switch_threadpool_worker_threads_max",
          "legendFormat": "Worker threads max"
        }
      ]
    },
    {
      "title": "ThreadPool — Pending Work Items",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 44 },
      "targets": [
        {
          "expr": "switch_threadpool_pending_work_items",
          "legendFormat": "Pending work items"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "fillOpacity": 30 }
        }
      }
    },
    {
      "title": "Process Threads",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 44 },
      "targets": [
        {
          "expr": "switch_process_thread_count",
          "legendFormat": "threads"
        }
      ]
    },
    {
      "title": "GC Collections (Gen0/1/2)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 44 },
      "targets": [
        {
          "expr": "rate(switch_gc_gen0_collections[5m])",
          "legendFormat": "Gen 0"
        },
        {
          "expr": "rate(switch_gc_gen1_collections[5m])",
          "legendFormat": "Gen 1"
        },
        {
          "expr": "rate(switch_gc_gen2_collections[5m])",
          "legendFormat": "Gen 2"
        }
      ]
    },
    {
      "title": "Managed Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 44 },
      "targets": [
        {
          "expr": "switch_gc_total_memory_bytes",
          "legendFormat": "Managed heap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 15 }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["synergy", "switch", "payments"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SynergySwitch - Payment Processing",
  "uid": "synergy-switch-main",
  "version": 1
}
