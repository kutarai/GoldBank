{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Grpc": "Information",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=unibank;Username=unibank;Password=UniBankPass#1"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "UniBank",
    "Audience": "UniBank.Clients",
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_USE_VAULT_OR_ENV_VAR",
    "TokenLifetimeMinutes": 60,
    "ClockSkewSeconds": 30,
    "AnonymousMethods": [
      "/unibank.v1.accounts.AccountService/Register",
      "/unibank.v1.accounts.AccountService/VerifyOTP",
      "/unibank.v1.accounts.AccountService/CreatePIN",
      "/unibank.v1.accounts.AccountService/Authenticate",
      "/unibank.v1.accounts.AccountService/RefreshToken",
      "/grpc.health.v1.Health/Check",
      "/grpc.health.v1.Health/Watch"
    ]
  },
  "RateLimit": {
    "Enabled": true,
    "UserMaxRequests": 100,
    "UserWindowSeconds": 60,
    "TenantMaxRequests": 10000,
    "TenantWindowSeconds": 60,
    "ExemptMethods": [
      "/grpc.health.v1.Health/Check",
      "/grpc.health.v1.Health/Watch"
    ]
  },
  "Ollama": {
    "BaseUrl": "http://unibank-ollama:11434",
    "Model": "qwen3-vl",
    "TimeoutSeconds": 120,
    "MaxTokens": 2048,
    "Temperature": 0.0
  },
  "FaceMatching": {
    "ModelPath": "/app/models/arcface_model.onnx",
    "ApproveThreshold": 0.6,
    "ReviewThreshold": 0.4,
    "InputSize": 112
  },
  "Routing": {
    "Services": {
      "AccountService": {
        "ProtoPackage": "unibank.v1.accounts",
        "Description": "Account registration, profile, balance, and transaction history"
      },
      "PaymentService": {
        "ProtoPackage": "unibank.v1.payments",
        "Description": "NFC and QR code payment processing"
      },
      "TransferService": {
        "ProtoPackage": "unibank.v1.transfers",
        "Description": "P2P and cross-border money transfers"
      },
      "AgentService": {
        "ProtoPackage": "unibank.v1.agents",
        "Description": "Agent cash-in, cash-out, and float management"
      },
      "BillPayService": {
        "ProtoPackage": "unibank.v1.billpay",
        "Description": "Bill payment and biller management"
      },
      "MerchantService": {
        "ProtoPackage": "unibank.v1.merchants",
        "Description": "Merchant registration and settlement"
      },
      "TerminalService": {
        "ProtoPackage": "unibank.v1.terminals",
        "Description": "POS terminal management and updates"
      },
      "AdminService": {
        "ProtoPackage": "unibank.v1.admin",
        "Description": "Back-office administration"
      },
      "ReportingService": {
        "ProtoPackage": "unibank.v1.reporting",
        "Description": "Analytics and reporting"
      },
      "HSMService": {
        "ProtoPackage": "unibank.v1.hsm",
        "Description": "Hardware security module cryptographic operations"
      }
    }
  }
}
