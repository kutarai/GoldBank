{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Grpc": "Debug",
        "Grpc.AspNetCore.Server": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff} {Level:u3}] {SourceContext}{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "DetailedErrors": true,
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false,connectTimeout=3000"
  },
  "Jwt": {
    "SecretKey": "DevOnly_SuperSecretKey_MinLength32Chars!!",
    "TokenLifetimeMinutes": 480,
    "ClockSkewSeconds": 60,
    "AnonymousMethods": [
      "/goldbank.v1.accounts.AccountService/Register",
      "/goldbank.v1.accounts.AccountService/VerifyOTP",
      "/goldbank.v1.accounts.AccountService/CreatePIN",
      "/goldbank.v1.accounts.AccountService/Authenticate",
      "/goldbank.v1.accounts.AccountService/RefreshToken",
      "/grpc.health.v1.Health/Check",
      "/grpc.health.v1.Health/Watch",
      "/grpc.reflection.v1alpha.ServerReflection/ServerReflectionInfo",
      "/goldbank.v1.admin.AdminService/AuthenticateAdmin",
      "/goldbank.v1.admin.AdminService/SearchCustomers",
      "/goldbank.v1.admin.AdminService/ManageAccount",
      "/goldbank.v1.admin.AdminService/ManageMerchant",
      "/goldbank.v1.admin.AdminService/SearchTransactions",
      "/goldbank.v1.admin.AdminService/ReviewKYC",
      "/goldbank.v1.admin.AdminService/UpdateSystemConfig",
      "/goldbank.v1.admin.AdminService/ListDisputes",
      "/goldbank.v1.admin.AdminService/CreateDispute",
      "/goldbank.v1.admin.AdminService/ResolveDispute",
      "/goldbank.v1.admin.AdminService/GetFraudAlerts",
      "/goldbank.v1.admin.AdminService/ReviewFraudAlert",
      "/goldbank.v1.reporting.ReportingService/GetDashboard",
      "/goldbank.v1.reporting.ReportingService/GetUserGrowthReport",
      "/goldbank.v1.reporting.ReportingService/GetMerchantReport",
      "/goldbank.v1.reporting.ReportingService/GetRevenueReport",
      "/goldbank.v1.reporting.ReportingService/GetReconReport",
      "/goldbank.v1.reporting.ReportingService/ExportReport"
    ]
  },
  "RateLimit": {
    "Enabled": false,
    "UserMaxRequests": 1000,
    "UserWindowSeconds": 60,
    "TenantMaxRequests": 100000,
    "TenantWindowSeconds": 60
  }
}
