# GoldBank Development Environment Variables
# Copy this file to .env and adjust values as needed
# DO NOT commit .env to version control

# PostgreSQL
POSTGRES_USER=goldbank
POSTGRES_PASSWORD=goldbank_dev_password
POSTGRES_DB=goldbank
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# JWT
JWT_SECRET=dev-secret-key-change-in-production-min-32-chars!!
JWT_ISSUER=goldbank-dev
JWT_AUDIENCE=goldbank-api

# Services
GATEWAY_PORT=5000
ADMIN_PORT=5010
CORE_PORT=5002
SWITCHING_PORT=5003
TERMINAL_MANAGER_PORT=5004
HSM_PORT=5005
REPORTING_PORT=5006
NOTIFICATIONS_PORT=5007

# MQTT
MQTT_PORT=1883

# Monitoring
GRAFANA_ADMIN_PASSWORD=admin
ELASTICSEARCH_MEMORY=512m

# Logging
LOG_LEVEL=Debug
ASPNETCORE_ENVIRONMENT=Development
