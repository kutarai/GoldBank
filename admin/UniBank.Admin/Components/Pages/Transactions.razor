@page "/transactions"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject AdminService.AdminServiceClient AdminClient
@inject ISnackbar Snackbar

<PageTitle>Transactions</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Transaction Search</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudTextField @bind-Value="_accountId" Label="Account ID" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudTextField @bind-Value="_merchantId" Label="Merchant ID" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudTextField @bind-Value="_reference" Label="Reference" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect @bind-Value="_typeFilter" Label="Type" Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem Value="@("")">All</MudSelectItem>
                <MudSelectItem Value="@("transfer")">Transfer</MudSelectItem>
                <MudSelectItem Value="@("payment")">Payment</MudSelectItem>
                <MudSelectItem Value="@("deposit")">Deposit</MudSelectItem>
                <MudSelectItem Value="@("withdrawal")">Withdrawal</MudSelectItem>
                <MudSelectItem Value="@("airtime")">Airtime</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect @bind-Value="_statusFilter" Label="Status" Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem Value="@("")">All</MudSelectItem>
                <MudSelectItem Value="@("completed")">Completed</MudSelectItem>
                <MudSelectItem Value="@("pending")">Pending</MudSelectItem>
                <MudSelectItem Value="@("failed")">Failed</MudSelectItem>
                <MudSelectItem Value="@("reversed")">Reversed</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudDateRangePicker @bind-DateRange="_dateRange" Label="Date Range" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudTextField @bind-Value="_minAmount" Label="Min Amount" Variant="Variant.Outlined" InputType="InputType.Number" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudTextField @bind-Value="_maxAmount" Label="Max Amount" Variant="Variant.Outlined" InputType="InputType.Number" />
        </MudItem>
        <MudItem xs="12" Class="d-flex justify-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchTransactions"
                       Disabled="_loading" StartIcon="@Icons.Material.Filled.Search">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Searching...</span>
                }
                else
                {
                    <span>Search</span>
                }
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable Items="_transactions" Dense="true" Hover="true" Striped="true" Loading="_loading" Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        <MudTh>ID</MudTh>
        <MudTh>Account</MudTh>
        <MudTh>Phone</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>Amount</MudTh>
        <MudTh>Fee</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Reference</MudTh>
        <MudTh>Counterparty</MudTh>
        <MudTh>Date</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">
            <MudTooltip Text="@context.TransactionId">
                @Truncate(context.TransactionId)
            </MudTooltip>
        </MudTd>
        <MudTd DataLabel="Account">@context.AccountId</MudTd>
        <MudTd DataLabel="Phone">@context.AccountPhone</MudTd>
        <MudTd DataLabel="Type">@context.Type</MudTd>
        <MudTd DataLabel="Amount">@FormatMoney(context.Amount)</MudTd>
        <MudTd DataLabel="Fee">@FormatMoney(context.Fee)</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">
                @context.Status
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Reference">@context.Reference</MudTd>
        <MudTd DataLabel="Counterparty">@context.CounterpartyInfo</MudTd>
        <MudTd DataLabel="Date">@FormatTimestamp(context.CreatedAt)</MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No transactions found.</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private string _accountId = "";
    private string _merchantId = "";
    private string _reference = "";
    private string _typeFilter = "";
    private string _statusFilter = "";
    private MudBlazor.DateRange? _dateRange;
    private string _minAmount = "";
    private string _maxAmount = "";
    private bool _loading;
    private int _page = 1;
    private int _pageSize = 50;

    private readonly List<AdminTransactionResponse> _transactions = new();

    private async Task SearchTransactions()
    {
        _loading = true;
        _transactions.Clear();
        StateHasChanged();

        try
        {
            var request = new SearchTransactionsRequest
            {
                AccountId = _accountId ?? "",
                MerchantId = _merchantId ?? "",
                Reference = _reference ?? "",
                TypeFilter = _typeFilter ?? "",
                StatusFilter = _statusFilter ?? "",
                Pagination = new PaginationRequest
                {
                    Page = _page,
                    PageSize = _pageSize,
                    SortBy = "created_at",
                    Descending = true
                }
            };

            if (_dateRange?.Start is not null && _dateRange?.End is not null)
            {
                request.DateRange = new UniBank.Protos.Common.DateRange
                {
                    From = Timestamp.FromDateTime(DateTime.SpecifyKind(_dateRange.Start.Value, DateTimeKind.Utc)),
                    To = Timestamp.FromDateTime(DateTime.SpecifyKind(_dateRange.End.Value, DateTimeKind.Utc))
                };
            }

            if (!string.IsNullOrWhiteSpace(_minAmount))
            {
                request.MinAmount = new Money { Amount = _minAmount };
            }

            if (!string.IsNullOrWhiteSpace(_maxAmount))
            {
                request.MaxAmount = new Money { Amount = _maxAmount };
            }

            var stream = AdminClient.SearchTransactions(request);
            await foreach (var item in stream.ResponseStream.ReadAllAsync())
            {
                _transactions.Add(item);
                StateHasChanged();
            }

            Snackbar.Add($"Found {_transactions.Count} transaction(s).", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error searching transactions: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string FormatMoney(Money? money)
    {
        if (money is null || string.IsNullOrWhiteSpace(money.Amount))
            return "$0.00";

        var amount = decimal.Parse(money.Amount);
        return $"${amount:N2}";
    }

    private static string FormatTimestamp(Timestamp? timestamp)
    {
        if (timestamp is null)
            return "-";

        return timestamp.ToDateTime().ToString("yyyy-MM-dd HH:mm");
    }

    private static string Truncate(string value, int maxLength = 8)
    {
        if (string.IsNullOrEmpty(value))
            return "-";

        return value.Length <= maxLength ? value : value[..maxLength] + "...";
    }

    private static Color GetStatusColor(string status) => status?.ToLowerInvariant() switch
    {
        "completed" => Color.Success,
        "pending" => Color.Warning,
        "failed" => Color.Error,
        "reversed" => Color.Info,
        _ => Color.Default
    };
}
