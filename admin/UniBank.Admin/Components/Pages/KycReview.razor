    // ──────────────────────────────────────────────────────────────────────────
    // Queue item model
    // ──────────────────────────────────────────────────────────────────────────

    private sealed class KycQueueItem
    {
        public string   DocumentId          { get; init; } = string.Empty;
        public string   AccountId           { get; init; } = string.Empty;
        public string   FullName            { get; init; } = string.Empty;
        public DateTime SubmittedDate       { get; init; }
        public double   FaceMatchScore      { get; init; }
        public string   FaceMatchConfidence { get; init; } = string.Empty;
        public string   AiDecision          { get; init; } = string.Empty;
        public string   NameMatch           { get; init; } = string.Empty;
        public string   IdNumberMatch       { get; init; } = string.Empty;
        public string   DobMatch            { get; init; } = string.Empty;
        public string?  ExtractedName       { get; init; }
        public string?  ExtractedIdNumber   { get; init; }
        public string?  ExtractedDob        { get; init; }
        public string   RejectionReason     { get; init; } = string.Empty;
    }
}
