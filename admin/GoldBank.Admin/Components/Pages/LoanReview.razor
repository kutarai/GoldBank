@page "/loans"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = AdminRoles.LoanAccess)]
@inject AdminService.AdminServiceClient AdminClient
@inject ISnackbar Snackbar

<PageTitle>Loan Review - GoldBank Admin</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Loan Review Dashboard</MudText>

@* ── Stats Cards ─────────────────────────────────────────────────────────── *@
<MudGrid Class="mb-6">
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2"
                  Style="border-top: 4px solid var(--mud-palette-warning);">
            <MudText Typo="Typo.h3" Color="Color.Warning">@_statsPending</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Pending Applications</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2"
                  Style="border-top: 4px solid var(--mud-palette-success);">
            <MudText Typo="Typo.h3" Color="Color.Success">@_statsApprovedThisMonth</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Approved This Month</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2"
                  Style="border-top: 4px solid var(--mud-palette-error);">
            <MudText Typo="Typo.h3" Color="Color.Error">@_statsRejectedThisMonth</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Rejected This Month</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@* ── Pending Applications Grid ────────────────────────────────────────────── *@
<MudPaper Elevation="2" Class="pa-0 mb-4">
    <MudDataGrid T="LoanQueueItem"
                 Items="_queue"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 Loading="_loading"
                 LoadingProgressColor="Color.Primary"
                 RowClick="OnRowClick"
                 Class="cursor-pointer">
        <ToolBarContent>
            <MudText Typo="Typo.h6" Class="px-4 py-2">Pending Applications</MudText>
            <MudSpacer />
            <MudTooltip Text="Refresh queue">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Primary"
                               OnClick="LoadQueueAsync"
                               Disabled="_loading" />
            </MudTooltip>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.ApplicantName"   Title="Applicant Name" />
            <TemplateColumn Title="Amount" SortBy="x => x.AmountValue">
                <CellTemplate>
                    <MudText Typo="Typo.body2">
                        @context.Item.Currency @context.Item.AmountValue.ToString("N2")
                    </MudText>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Tenure" SortBy="x => x.TenureMonths">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@context.Item.TenureMonths mo</MudText>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Purpose"         Title="Purpose" />
            <TemplateColumn Title="Credit Score" SortBy="x => x.CreditScore">
                <CellTemplate>
                    @if (context.Item.CreditScore > 0)
                    {
                        <MudChip T="string"
                                 Color="@GetCreditScoreColor(context.Item.CreditScore)"
                                 Size="Size.Small">
                            @context.Item.CreditScore
                        </MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">N/A</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="AI Doc Verification">
                <CellTemplate>
                    <MudChip T="string"
                             Color="@GetAiVerificationColor(context.Item.AiVerificationStatus)"
                             Size="Size.Small"
                             Icon="@GetAiVerificationIcon(context.Item.AiVerificationStatus)">
                        @context.Item.AiVerificationStatus
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.AppliedDate"     Title="Applied Date" Format="yyyy-MM-dd HH:mm" />
            <TemplateColumn Title="Action" Sortable="false">
                <CellTemplate>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.RateReview"
                               OnClick="@(() => OpenReviewDialog(context.Item))">
                        Review
                    </MudButton>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudText Class="pa-4">No loan applications pending review.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudDataGridPager T="LoanQueueItem" PageSizeOptions="new[] { 10, 25, 50 }" />
        </PagerContent>
    </MudDataGrid>
</MudPaper>

@* ── Review Dialog ────────────────────────────────────────────────────────── *@
<MudDialog @bind-Visible="_reviewDialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" />
            <MudText Typo="Typo.h6">
                Loan Review — @(_selectedItem?.ApplicantName ?? "")
            </MudText>
        </MudStack>
    </TitleContent>

    <DialogContent>
        @if (_selectedItem is not null)
        {
            <MudGrid Spacing="4">

                @* Left column — Applicant & Loan details *@
                <MudItem xs="12" md="5">

                    @* Applicant profile summary *@
                    <MudPaper Outlined="true" Class="pa-4 mb-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                            <MudAvatar Color="Color.Primary" Style="width:56px; height:56px;">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size:32px;" />
                            </MudAvatar>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h6">@_selectedItem.ApplicantName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @_selectedItem.AccountId
                                </MudText>
                            </MudStack>
                        </MudStack>
                        <MudSimpleTable Dense="true" Bordered="false">
                            <tbody>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Secondary">Phone</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_selectedItem.Phone</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_selectedItem.Email</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption" Color="Color.Secondary">KYC Level</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_selectedItem.KycLevel</MudText></td>
                                </tr>
                                @if (_selectedItem.CreditScore > 0)
                                {
                                    <tr>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">Credit Score</MudText></td>
                                        <td>
                                            <MudChip T="string"
                                                     Color="@GetCreditScoreColor(_selectedItem.CreditScore)"
                                                     Size="Size.Small">
                                                @_selectedItem.CreditScore
                                            </MudChip>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>

                    @* Loan details *@
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Loan Details</MudText>
                    <MudSimpleTable Dense="true" Striped="true" Bordered="true" Class="mb-4">
                        <tbody>
                            <tr>
                                <td><MudText Typo="Typo.body2">Amount Requested</MudText></td>
                                <td>
                                    <MudText Typo="Typo.body2">
                                        <strong>@_selectedItem.Currency @_selectedItem.AmountValue.ToString("N2")</strong>
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2">Tenure</MudText></td>
                                <td><MudText Typo="Typo.body2">@_selectedItem.TenureMonths months</MudText></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2">Purpose</MudText></td>
                                <td><MudText Typo="Typo.body2">@_selectedItem.Purpose</MudText></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2">Est. Monthly Repayment</MudText></td>
                                <td>
                                    <MudText Typo="Typo.body2" Color="Color.Primary">
                                        <strong>@_selectedItem.Currency @_selectedItem.MonthlyRepayment.ToString("N2")</strong>
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2">Applied Date</MudText></td>
                                <td>
                                    <MudText Typo="Typo.body2">
                                        @_selectedItem.AppliedDate.ToString("yyyy-MM-dd HH:mm")
                                    </MudText>
                                </td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>

                </MudItem>

                @* Right column — AI verification + decision *@
                <MudItem xs="12" md="7">

                    @* AI document verification results *@
                    @if (_selectedItem.AiVerificationStatus != "Not Available")
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">AI Document Verification Results</MudText>

                        @* Income variance warning *@
                        @if (_selectedItem.IncomeVariancePercent > 10.0)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3"
                                      Icon="@Icons.Material.Filled.Warning">
                                <strong>Income Variance Warning:</strong>
                                Declared vs extracted income differs by
                                <strong>@_selectedItem.IncomeVariancePercent.ToString("0.0")%</strong>
                                (threshold: 10%). Manual verification recommended.
                            </MudAlert>
                        }

                        <MudSimpleTable Dense="true" Striped="true" Bordered="true" Class="mb-4">
                            <thead>
                                <tr>
                                    <th>Field</th>
                                    <th>Extracted Value</th>
                                    <th>Match</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><MudText Typo="Typo.body2">Name</MudText></td>
                                    <td>
                                        <MudText Typo="Typo.body2">
                                            @(_selectedItem.ExtractedName ?? "—")
                                        </MudText>
                                    </td>
                                    <td>@FieldMatchChip(_selectedItem.NameMatch)</td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2">Employer</MudText></td>
                                    <td>
                                        <MudText Typo="Typo.body2">
                                            @(_selectedItem.ExtractedEmployer ?? "—")
                                        </MudText>
                                    </td>
                                    <td>@FieldMatchChip(_selectedItem.EmployerMatch)</td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2">Monthly Income</MudText></td>
                                    <td>
                                        <MudText Typo="Typo.body2">
                                            @(_selectedItem.ExtractedIncome > 0
                                                ? $"{_selectedItem.Currency} {_selectedItem.ExtractedIncome:N2}"
                                                : "—")
                                        </MudText>
                                    </td>
                                    <td>
                                        @if (_selectedItem.IncomeVariancePercent > 0)
                                        {
                                            <MudChip T="string"
                                                     Color="@(_selectedItem.IncomeVariancePercent > 10 ? Color.Error : Color.Success)"
                                                     Size="Size.Small">
                                                @_selectedItem.IncomeVariancePercent.ToString("0.0")% variance
                                            </MudChip>
                                        }
                                        else
                                        {
                                            @FieldMatchChip("NotAvailable")
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>

                        <MudAlert Severity="@GetAiVerificationSeverity(_selectedItem.AiVerificationStatus)"
                                  Dense="true" Class="mb-4">
                            <strong>AI Verification:</strong> @_selectedItem.AiVerificationStatus
                        </MudAlert>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Normal" Dense="true" Class="mb-4"
                                  Icon="@Icons.Material.Filled.Info">
                            AI document verification results are not available for this application.
                        </MudAlert>
                    }

                    <MudDivider Class="mb-4" />

                    @* Admin decision controls *@
                    <MudText Typo="Typo.subtitle2" Class="mb-3">Decision</MudText>

                    <MudStack Row="true" Spacing="2" Class="mb-3" Wrap="Wrap.Wrap">
                        <MudButton Variant="@(_pendingDecision == LoanDecision.Approve ? Variant.Filled : Variant.Outlined)"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   OnClick="@(() => SelectDecision(LoanDecision.Approve))">
                            Approve
                        </MudButton>
                        <MudButton Variant="@(_pendingDecision == LoanDecision.Reject ? Variant.Filled : Variant.Outlined)"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Cancel"
                                   OnClick="@(() => SelectDecision(LoanDecision.Reject))">
                            Reject
                        </MudButton>
                        <MudButton Variant="@(_pendingDecision == LoanDecision.RequestDocuments ? Variant.Filled : Variant.Outlined)"
                                   Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.UploadFile"
                                   OnClick="@(() => SelectDecision(LoanDecision.RequestDocuments))">
                            Request More Documents
                        </MudButton>
                    </MudStack>

                    @* Reject reason — only visible when Reject is selected *@
                    @if (_pendingDecision == LoanDecision.Reject)
                    {
                        <MudTextField @bind-Value="_rejectReason"
                                      Label="Rejection Reason"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      Required="true"
                                      RequiredError="A rejection reason is required."
                                      Placeholder="Describe why this application is being rejected…"
                                      Class="mb-3" />
                    }

                    @* Document request notes — only visible when requesting documents *@
                    @if (_pendingDecision == LoanDecision.RequestDocuments)
                    {
                        <MudTextField @bind-Value="_documentRequest"
                                      Label="Documents Required"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      Required="true"
                                      RequiredError="Please specify which documents are required."
                                      Placeholder="List the additional documents required from the applicant…"
                                      Class="mb-3" />
                    }

                    <MudTextField @bind-Value="_reviewNotes"
                                  Label="Additional Notes (optional)"
                                  Variant="Variant.Outlined"
                                  Lines="2"
                                  Placeholder="Any additional notes for audit trail…" />

                </MudItem>

            </MudGrid>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="CloseReviewDialog" Disabled="_submitting">
            Cancel
        </MudButton>
        <MudButton Color="@GetDecisionButtonColor()"
                   Variant="Variant.Filled"
                   Disabled="@(!CanSubmit())"
                   OnClick="SubmitReviewAsync">
            @if (_submitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Submit Decision
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    // ──────────────────────────────────────────────────────────────────────────
    // Stats (placeholder — no admin ListPendingLoans RPC yet)
    // ──────────────────────────────────────────────────────────────────────────

    private int _statsPending            = 0;
    private int _statsApprovedThisMonth  = 18;
    private int _statsRejectedThisMonth  = 4;

    // ──────────────────────────────────────────────────────────────────────────
    // Queue state
    // ──────────────────────────────────────────────────────────────────────────

    private bool _loading;
    private List<LoanQueueItem> _queue = [];

    // ──────────────────────────────────────────────────────────────────────────
    // Dialog state
    // ──────────────────────────────────────────────────────────────────────────

    private bool            _reviewDialogVisible;
    private bool            _submitting;
    private LoanQueueItem?  _selectedItem;
    private LoanDecision    _pendingDecision  = LoanDecision.Approve;
    private string          _rejectReason     = string.Empty;
    private string          _documentRequest  = string.Empty;
    private string          _reviewNotes      = string.Empty;

    private readonly DialogOptions _dialogOptions = new()
    {
        CloseOnEscapeKey = true,
        MaxWidth         = MaxWidth.Large,
        FullWidth        = true,
    };

    // ──────────────────────────────────────────────────────────────────────────
    // Lifecycle
    // ──────────────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadQueueAsync();
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Queue loading (stub data — no admin ListPendingLoans RPC yet)
    // ──────────────────────────────────────────────────────────────────────────

    private async Task LoadQueueAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            // No dedicated admin queue RPC exists yet; use stub data so the
            // page remains interactive during development.
            await Task.Delay(200); // Simulate network round-trip.
            _queue = GetStubQueue();
            _statsPending = _queue.Count;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading loan queue: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Row click → open dialog
    // ──────────────────────────────────────────────────────────────────────────

    private void OnRowClick(DataGridRowClickEventArgs<LoanQueueItem> args)
    {
        OpenReviewDialog(args.Item);
    }

    private void OpenReviewDialog(LoanQueueItem item)
    {
        _selectedItem        = item;
        _pendingDecision     = LoanDecision.Approve;
        _rejectReason        = string.Empty;
        _documentRequest     = string.Empty;
        _reviewNotes         = string.Empty;
        _reviewDialogVisible = true;
    }

    private void CloseReviewDialog()
    {
        _reviewDialogVisible = false;
        _selectedItem        = null;
    }

    private void SelectDecision(LoanDecision decision)
    {
        _pendingDecision = decision;
        if (decision != LoanDecision.Reject)
            _rejectReason = string.Empty;
        if (decision != LoanDecision.RequestDocuments)
            _documentRequest = string.Empty;
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Submit review (stub — no admin loan review RPC yet)
    // ──────────────────────────────────────────────────────────────────────────

    private async Task SubmitReviewAsync()
    {
        if (_selectedItem is null || !CanSubmit()) return;

        _submitting = true;

        try
        {
            // Stub: simulate API call until admin loan review RPC is available.
            await Task.Delay(400);

            var decisionLabel = FormatDecision(_pendingDecision);
            Snackbar.Add(
                $"Loan decision '{decisionLabel}' submitted for {_selectedItem.ApplicantName}.",
                Severity.Success);

            _queue.Remove(_selectedItem);
            _statsPending = _queue.Count;

            if (_pendingDecision == LoanDecision.Approve)
                _statsApprovedThisMonth++;
            else if (_pendingDecision == LoanDecision.Reject)
                _statsRejectedThisMonth++;

            _reviewDialogVisible = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error submitting loan review: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting   = false;
            _selectedItem = null;
        }
    }

    // ──────────────────────────────────────────────────────────────────────────
    // Guards & helpers
    // ──────────────────────────────────────────────────────────────────────────

    private bool CanSubmit()
    {
        if (_submitting || _selectedItem is null) return false;
        if (_pendingDecision == LoanDecision.Reject &&
            string.IsNullOrWhiteSpace(_rejectReason))
            return false;
        if (_pendingDecision == LoanDecision.RequestDocuments &&
            string.IsNullOrWhiteSpace(_documentRequest))
            return false;
        return true;
    }

    private static Color GetCreditScoreColor(int score) => score switch
    {
        >= 700 => Color.Success,
        >= 550 => Color.Warning,
        _      => Color.Error,
    };

    private static Color GetAiVerificationColor(string status) => status switch
    {
        "Verified"     => Color.Success,
        "Partial"      => Color.Warning,
        "Failed"       => Color.Error,
        _              => Color.Default,
    };

    private static string GetAiVerificationIcon(string status) => status switch
    {
        "Verified"     => Icons.Material.Filled.Verified,
        "Partial"      => Icons.Material.Filled.WarningAmber,
        "Failed"       => Icons.Material.Filled.GppBad,
        _              => Icons.Material.Filled.HelpOutline,
    };

    private static Severity GetAiVerificationSeverity(string status) => status switch
    {
        "Verified" => Severity.Success,
        "Partial"  => Severity.Warning,
        "Failed"   => Severity.Error,
        _          => Severity.Normal,
    };

    private static string FormatDecision(LoanDecision decision) => decision switch
    {
        LoanDecision.Approve          => "Approve",
        LoanDecision.Reject           => "Reject",
        LoanDecision.RequestDocuments => "Request More Documents",
        _                             => "Unknown",
    };

    private Color GetDecisionButtonColor() => _pendingDecision switch
    {
        LoanDecision.Approve          => Color.Success,
        LoanDecision.Reject           => Color.Error,
        LoanDecision.RequestDocuments => Color.Warning,
        _                             => Color.Primary,
    };

    private RenderFragment FieldMatchChip(string match) => __builder =>
    {
        var (color, label, icon) = match switch
        {
            "Match"        => (Color.Success, "Match",    Icons.Material.Filled.Check),
            "Mismatch"     => (Color.Error,   "Mismatch", Icons.Material.Filled.Close),
            "NotAvailable" => (Color.Default, "N/A",      Icons.Material.Filled.HelpOutline),
            _              => (Color.Default, match,      Icons.Material.Filled.HelpOutline),
        };

        <MudChip T="string" Color="@color" Size="Size.Small" Icon="@icon">@label</MudChip>
    };

