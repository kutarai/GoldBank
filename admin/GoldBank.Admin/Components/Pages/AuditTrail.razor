@page "/audit"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = AdminRoles.ReportAccess)]

<PageTitle>Audit Trail - GoldBank Admin</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Audit Trail</MudText>

@* ── Filters ──────────────────────────────────────────────────────────────── *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect @bind-Value="_adminUserFilter"
                       Label="Admin User"
                       Variant="Variant.Outlined"
                       Clearable="true">
                <MudSelectItem Value="@("")">All Users</MudSelectItem>
                @foreach (var user in _adminUsers)
                {
                    <MudSelectItem Value="@user">@user</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect @bind-Value="_actionTypeFilter"
                       Label="Action Type"
                       Variant="Variant.Outlined"
                       Clearable="true">
                <MudSelectItem Value="@("")">All Actions</MudSelectItem>
                <MudSelectItem Value="@("Login")">Login</MudSelectItem>
                <MudSelectItem Value="@("KYC Review")">KYC Review</MudSelectItem>
                <MudSelectItem Value="@("Dispute Resolution")">Dispute Resolution</MudSelectItem>
                <MudSelectItem Value="@("Account Action")">Account Action</MudSelectItem>
                <MudSelectItem Value="@("Config Change")">Config Change</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudDateRangePicker @bind-DateRange="_dateRange"
                                Label="Date Range"
                                Variant="Variant.Outlined"
                                AutoClose="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="ApplyFilters"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.FilterList">
                Filter
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@* ── Data Grid ────────────────────────────────────────────────────────────── *@
<MudDataGrid T="AuditLogEntry"
             Items="_filteredEntries"
             Dense="true"
             Hover="true"
             Striped="true"
             Bordered="true"
             ReadOnly="true"
             RowsPerPage="20">
    <Columns>
        <PropertyColumn Property="x => x.Timestamp" Title="Timestamp" Format="yyyy-MM-dd HH:mm:ss" />
        <PropertyColumn Property="x => x.AdminUser"  Title="Admin User" />
        <PropertyColumn Property="x => x.ActionType" Title="Action" />
        <PropertyColumn Property="x => x.EntityType" Title="Entity Type" />
        <PropertyColumn Property="x => x.EntityId"   Title="Entity ID" />
        <TemplateColumn Title="Details" CellStyle="max-width:260px;overflow:hidden;">
            <CellTemplate>
                <MudTooltip Text="@context.Item.Details" Placement="Placement.Left">
                    <MudText Typo="Typo.body2"
                             Style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:240px;display:block;">
                        @TruncateDetails(context.Item.Details)
                    </MudText>
                </MudTooltip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.IpAddress" Title="IP Address" />
    </Columns>
    <ChildRowContent>
        <MudPaper Class="pa-3 mx-4 mb-2" Elevation="0" Style="background:#f5f5f5;">
            <MudText Typo="Typo.subtitle2" Class="mb-1">Full Details</MudText>
            <pre style="white-space:pre-wrap;word-break:break-all;font-size:0.8rem;margin:0;">@context.Item.Details</pre>
        </MudPaper>
    </ChildRowContent>
    <NoRecordsContent>
        <MudText>No audit entries match the current filters.</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudDataGridPager T="AuditLogEntry" />
    </PagerContent>
</MudDataGrid>

@code {
    private string _adminUserFilter = "";
    private string _actionTypeFilter = "";
    private MudBlazor.DateRange? _dateRange = new(DateTime.Today.AddDays(-7), DateTime.Today);

    private List<AuditLogEntry> _allEntries = [];
    private List<AuditLogEntry> _filteredEntries = [];

    private static readonly string[] _adminUsers =
    [
        "admin@goldbank.co.zw",
        "kyc.officer@goldbank.co.zw",
        "compliance@goldbank.co.zw",
        "branch.manager@goldbank.co.zw"
    ];

    protected override void OnInitialized()
    {
        _allEntries = GenerateStubData();
        _filteredEntries = [.. _allEntries];
    }

    private void ApplyFilters()
    {
        _filteredEntries = _allEntries.Where(e =>
        {
            if (!string.IsNullOrWhiteSpace(_adminUserFilter) && e.AdminUser != _adminUserFilter)
                return false;

            if (!string.IsNullOrWhiteSpace(_actionTypeFilter) && e.ActionType != _actionTypeFilter)
                return false;

            if (_dateRange?.Start is not null && e.Timestamp.Date < _dateRange.Start.Value.Date)
                return false;

            if (_dateRange?.End is not null && e.Timestamp.Date > _dateRange.End.Value.Date)
                return false;

            return true;
        }).ToList();
    }

    private static string TruncateDetails(string details, int maxLen = 60)
    {
        if (string.IsNullOrEmpty(details))
            return "-";
        return details.Length <= maxLen ? details : details[..maxLen] + "…";
    }

    private static List<AuditLogEntry> GenerateStubData()
    {
        var rng = new Random(42);
        var actions = new[]
        {
            ("Login",              "Auth",     "{ \"method\": \"password\", \"mfa\": true }"),
            ("KYC Review",         "Customer", "{ \"decision\": \"approved\", \"tier\": 2, \"notes\": \"All documents verified\" }"),
            ("KYC Review",         "Customer", "{ \"decision\": \"rejected\", \"reason\": \"Document expired\" }"),
            ("Dispute Resolution", "Dispute",  "{ \"outcome\": \"resolved\", \"refund_amount\": \"150.00\", \"currency\": \"ZWG\" }"),
            ("Account Action",     "Account",  "{ \"action\": \"suspend\", \"reason\": \"Suspicious activity flagged\" }"),
            ("Account Action",     "Account",  "{ \"action\": \"reactivate\", \"reason\": \"Customer verified\" }"),
            ("Config Change",      "Config",   "{ \"key\": \"transfer.daily_limit\", \"old\": \"5000\", \"new\": \"10000\" }"),
            ("Config Change",      "Config",   "{ \"key\": \"fee.transfer_pct\", \"old\": \"0.5\", \"new\": \"0.75\" }"),
        };
        var users = _adminUsers;
        var ips = new[] { "10.0.1.12", "10.0.1.45", "192.168.2.100", "10.10.0.5" };

        var entries = new List<AuditLogEntry>();
        var baseTime = DateTime.UtcNow.AddDays(-7);

        for (int i = 0; i < 60; i++)
        {
            var (actionType, entityType, details) = actions[rng.Next(actions.Length)];
            var user = users[rng.Next(users.Length)];
            entries.Add(new AuditLogEntry
            {
                Timestamp  = baseTime.AddMinutes(rng.Next(0, 10_080)),
                AdminUser  = user,
                ActionType = actionType,
                EntityType = entityType,
                EntityId   = Guid.NewGuid().ToString("N")[..12],
                Details    = details,
                IpAddress  = ips[rng.Next(ips.Length)]
            });
        }

        return [.. entries.OrderByDescending(e => e.Timestamp)];
    }

    private sealed class AuditLogEntry
    {
        public DateTime Timestamp  { get; init; }
        public string AdminUser    { get; init; } = string.Empty;
        public string ActionType   { get; init; } = string.Empty;
        public string EntityType   { get; init; } = string.Empty;
        public string EntityId     { get; init; } = string.Empty;
        public string Details      { get; init; } = string.Empty;
        public string IpAddress    { get; init; } = string.Empty;
    }
}
