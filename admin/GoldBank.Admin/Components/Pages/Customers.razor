@page "/customers"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = AdminRoles.CustomerAccess)]
@inject AdminService.AdminServiceClient AdminClient
@inject ISnackbar Snackbar

<PageTitle>Customers - GoldBank Admin</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Customer Management</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="4">
        <MudTextField @bind-Value="_searchQuery"
                      Label="Search"
                      Placeholder="Name or phone number..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="false"
                      OnKeyUp="OnSearchKeyUp" />
    </MudItem>
    <MudItem xs="12" sm="4" md="3">
        <MudSelect @bind-Value="_statusFilter"
                   Label="Status Filter"
                   Variant="Variant.Outlined"
                   Clearable="true">
            <MudSelectItem Value="@("")">All</MudSelectItem>
            <MudSelectItem Value="@("ACTIVE")">Active</MudSelectItem>
            <MudSelectItem Value="@("SUSPENDED")">Suspended</MudSelectItem>
            <MudSelectItem Value="@("FROZEN")">Frozen</MudSelectItem>
            <MudSelectItem Value="@("CLOSED")">Closed</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="2" md="2">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SearchAsync"
                   Disabled="_loading"
                   FullWidth="true"
                   Class="mt-1">
            Search
        </MudButton>
    </MudItem>
</MudGrid>

<MudTable @ref="_table"
          ServerData="LoadCustomersAsync"
          Dense="true"
          Hover="true"
          Striped="true"
          Loading="_loading"
          LoadingProgressColor="Color.Primary"
          Elevation="2">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Phone</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>KYC Level</MudTh>
        <MudTh>Balance</MudTh>
        <MudTh>Created</MudTh>
        <MudTh>Last Login</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.FullName</MudTd>
        <MudTd DataLabel="Phone">@context.PhoneNumber</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string"
                     Color="@GetStatusColor(context.Status)"
                     Size="Size.Small">
                @context.Status
            </MudChip>
        </MudTd>
        <MudTd DataLabel="KYC Level">@context.KycLevel</MudTd>
        <MudTd DataLabel="Balance">@FormatMoney(context.Balance)</MudTd>
        <MudTd DataLabel="Created">@FormatTimestamp(context.CreatedAt)</MudTd>
        <MudTd DataLabel="Last Login">@FormatTimestamp(context.LastLoginAt)</MudTd>
        <MudTd>
            <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                     Size="Size.Small"
                     Dense="true"
                     AnchorOrigin="Origin.BottomLeft">
                <MudMenuItem Icon="@Icons.Material.Filled.PersonSearch"
                             OnClick="@(() => OpenDetailDialog(context))">
                    View Details
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem OnClick="@(() => ExecuteActionAsync(context, AccountAction.Activate))">
                    Activate
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => ExecuteActionAsync(context, AccountAction.Suspend))">
                    Suspend
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => ExecuteActionAsync(context, AccountAction.Freeze))">
                    Freeze
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => ExecuteActionAsync(context, AccountAction.Unfreeze))">
                    Unfreeze
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => ExecuteActionAsync(context, AccountAction.ResetPin))">
                    Reset PIN
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => ExecuteActionAsync(context, AccountAction.Close))">
                    Close
                </MudMenuItem>
            </MudMenu>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No customers found.</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@* ── Customer Detail Dialog ────────────────────────────────────────────── *@
<MudDialog @bind-Visible="_detailDialogVisible" Options="_detailDialogOptions">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" />
            <MudText Typo="Typo.h6">
                Customer Profile — @(_detailCustomer?.FullName ?? "")
            </MudText>
        </MudStack>
    </TitleContent>

    <DialogContent>
        @if (_detailCustomer is not null)
        {
            <MudGrid Spacing="4">

                @* Left column — Profile info + KYC *@
                <MudItem xs="12" md="5">

                    @* Avatar + status *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-4">
                        <MudAvatar Color="Color.Primary" Style="width:64px; height:64px;">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size:36px;" />
                        </MudAvatar>
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.h6">@_detailCustomer.FullName</MudText>
                            <MudChip T="string"
                                     Color="@GetStatusColor(_detailCustomer.Status)"
                                     Size="Size.Small">
                                @_detailCustomer.Status
                            </MudChip>
                        </MudStack>
                    </MudStack>

                    @* Profile fields *@
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Profile Information</MudText>
                    <MudSimpleTable Dense="true" Bordered="true" Striped="true" Class="mb-4">
                        <tbody>
                            <tr>
                                <td><MudText Typo="Typo.caption" Color="Color.Secondary">Phone</MudText></td>
                                <td><MudText Typo="Typo.body2">@_detailCustomer.PhoneNumber</MudText></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText></td>
                                <td>
                                    <MudText Typo="Typo.body2">
                                        @(_detailStub.Email ?? "—")
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.caption" Color="Color.Secondary">ID Number</MudText></td>
                                <td>
                                    <MudText Typo="Typo.body2">
                                        @(_detailStub.IdNumber ?? "—")
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.caption" Color="Color.Secondary">Member Since</MudText></td>
                                <td>
                                    <MudText Typo="Typo.body2">
                                        @FormatTimestamp(_detailCustomer.CreatedAt)
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.caption" Color="Color.Secondary">Last Login</MudText></td>
                                <td>
                                    <MudText Typo="Typo.body2">
                                        @FormatTimestamp(_detailCustomer.LastLoginAt)
                                    </MudText>
                                </td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>

                    @* KYC status *@
                    <MudText Typo="Typo.subtitle2" Class="mb-2">KYC Status</MudText>
                    <MudPaper Outlined="true" Class="pa-3 mb-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.VerifiedUser"
                                     Color="@GetKycColor(_detailCustomer.KycLevel)" />
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body1">
                                    <strong>Level @_detailCustomer.KycLevel</strong>
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    KYC Verification Level
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>

                    @* Counters — disputes & loans *@
                    <MudGrid Spacing="2" Class="mb-2">
                        <MudItem xs="6">
                            <MudPaper Outlined="true" Class="pa-3 d-flex flex-column align-center">
                                <MudText Typo="Typo.h5"
                                         Color="@(_detailStub.ActiveDisputesCount > 0 ? Color.Warning : Color.Default)">
                                    @_detailStub.ActiveDisputesCount
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Active Disputes</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6">
                            <MudPaper Outlined="true" Class="pa-3 d-flex flex-column align-center">
                                <MudText Typo="Typo.h5"
                                         Color="@(_detailStub.ActiveLoansCount > 0 ? Color.Info : Color.Default)">
                                    @_detailStub.ActiveLoansCount
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Active Loans</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                </MudItem>

                @* Right column — Balances + recent transactions *@
                <MudItem xs="12" md="7">

                    @* Account balances *@
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Account Balances</MudText>
                    <MudGrid Spacing="2" Class="mb-4">
                        <MudItem xs="6">
                            <MudPaper Outlined="true" Class="pa-3"
                                      Style="border-top: 3px solid var(--mud-palette-primary);">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">ZWG Balance</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Primary">
                                    ZWG @_detailStub.ZwgBalance.ToString("N2")
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6">
                            <MudPaper Outlined="true" Class="pa-3"
                                      Style="border-top: 3px solid var(--mud-palette-success);">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">USD Balance</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Success">
                                    USD @_detailStub.UsdBalance.ToString("N2")
                                </MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    @* Recent transactions *@
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Recent Transactions</MudText>
                    <MudSimpleTable Dense="true" Striped="true" Bordered="true" Class="mb-4">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Description</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in _detailStub.RecentTransactions)
                            {
                                <tr>
                                    <td>
                                        <MudText Typo="Typo.caption">
                                            @tx.Date.ToString("yyyy-MM-dd")
                                        </MudText>
                                    </td>
                                    <td>
                                        <MudText Typo="Typo.body2">@tx.Description</MudText>
                                    </td>
                                    <td>
                                        <MudText Typo="Typo.body2"
                                                 Color="@(tx.IsDebit ? Color.Error : Color.Success)">
                                            @(tx.IsDebit ? "-" : "+")@tx.Currency @tx.Amount.ToString("N2")
                                        </MudText>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>

                    @* Quick links *@
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Quick Links</MudText>
                    <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.VerifiedUser"
                                   Href="/kyc">
                            View KYC
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Warning"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Gavel"
                                   Href="/disputes">
                            View Disputes
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Info"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.AccountBalance"
                                   Href="/loans">
                            View Loans
                        </MudButton>
                    </MudStack>

                </MudItem>

            </MudGrid>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="CloseDetailDialog">Close</MudButton>
    </DialogActions>
</MudDialog>

@* Inline confirmation dialog *@
<MudDialog @bind-Visible="_dialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Confirm @_pendingActionName</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-4">
            Are you sure you want to @(_pendingActionName.ToLowerInvariant()) account for
            @(_pendingCustomer?.FullName) (@(_pendingCustomer?.PhoneNumber))?
        </MudText>
        <MudTextField @bind-Value="_actionReason"
                      Label="Reason"
                      Variant="Variant.Outlined"
                      Lines="3"
                      Required="true"
                      RequiredError="A reason is required." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@string.IsNullOrWhiteSpace(_actionReason)"
                   OnClick="ConfirmActionAsync">
            Confirm
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudTable<CustomerSummary>? _table;
    private string _searchQuery = string.Empty;
    private string _statusFilter = string.Empty;
    private bool _loading;

    // ── Confirmation dialog state ────────────────────────────────────────────
    private bool _dialogVisible;
    private readonly DialogOptions _dialogOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
    private CustomerSummary? _pendingCustomer;
    private AccountAction _pendingAction;
    private string _pendingActionName = string.Empty;
    private string _actionReason = string.Empty;

    // ── Customer detail dialog state ─────────────────────────────────────────
    private bool _detailDialogVisible;
    private readonly DialogOptions _detailDialogOptions = new()
    {
        CloseOnEscapeKey = true,
        MaxWidth         = MaxWidth.Large,
        FullWidth        = true,
    };
    private CustomerSummary? _detailCustomer;
    private CustomerDetailStub _detailStub = new();

    private async Task<TableData<CustomerSummary>> LoadCustomersAsync(TableState state, CancellationToken ct)
    {
        _loading = true;

        try
        {
            var request = new SearchCustomersRequest
            {
                Query = _searchQuery,
                StatusFilter = _statusFilter,
                Pagination = new PaginationRequest
                {
                    Page = state.Page + 1,
                    PageSize = state.PageSize
                }
            };

            var response = await AdminClient.SearchCustomersAsync(request, cancellationToken: ct);

            return new TableData<CustomerSummary>
            {
                Items = response.Customers,
                TotalItems = response.Pagination?.TotalCount ?? 0
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load customers: {ex.Message}", Severity.Error);
            return new TableData<CustomerSummary> { Items = [], TotalItems = 0 };
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SearchAsync()
    {
        if (_table is not null)
        {
            await _table.ReloadServerData();
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await SearchAsync();
        }
    }

    private Task ExecuteActionAsync(CustomerSummary customer, AccountAction action)
    {
        _pendingCustomer = customer;
        _pendingAction = action;
        _pendingActionName = GetActionName(action);
        _actionReason = string.Empty;
        _dialogVisible = true;
        return Task.CompletedTask;
    }

    private void CancelDialog()
    {
        _dialogVisible = false;
        _pendingCustomer = null;
        _actionReason = string.Empty;
    }

    private async Task ConfirmActionAsync()
    {
        if (_pendingCustomer is null || string.IsNullOrWhiteSpace(_actionReason))
            return;

        _dialogVisible = false;

        try
        {
            var request = new ManageAccountRequest
            {
                AccountId = _pendingCustomer.AccountId,
                Action = _pendingAction,
                Reason = _actionReason,
                AdminId = "current-admin"
            };

            var response = await AdminClient.ManageAccountAsync(request);

            if (response.Success)
            {
                Snackbar.Add($"Successfully performed {_pendingActionName} on {_pendingCustomer.FullName}.", Severity.Success);
                if (_table is not null)
                {
                    await _table.ReloadServerData();
                }
            }
            else
            {
                Snackbar.Add($"Action failed: {response.Message}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to {_pendingActionName}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _pendingCustomer = null;
            _actionReason = string.Empty;
        }
    }

    private static string GetActionName(AccountAction action)
    {
        return action switch
        {
            AccountAction.Activate => "Activate",
            AccountAction.Suspend => "Suspend",
            AccountAction.Close => "Close",
            AccountAction.Freeze => "Freeze",
            AccountAction.Unfreeze => "Unfreeze",
            AccountAction.ResetPin => "Reset PIN",
            _ => action.ToString()
        };
    }

    private static Color GetStatusColor(string status)
    {
        return status.ToUpperInvariant() switch
        {
            "ACTIVE" => Color.Success,
            "SUSPENDED" => Color.Warning,
            "FROZEN" => Color.Info,
            "CLOSED" => Color.Error,
            _ => Color.Default
        };
    }

    private static string FormatMoney(Money? money)
    {
        if (money is null || string.IsNullOrEmpty(money.Amount))
            return "ZWG 0.00";

        var amount = decimal.Parse(money.Amount);
        return $"ZWG {amount:N2}";
    }

    private static string FormatTimestamp(Timestamp? timestamp)
    {
        if (timestamp is null)
            return "-";

        return timestamp.ToDateTime().ToString("yyyy-MM-dd HH:mm");
    }

    // ── Customer detail dialog ───────────────────────────────────────────────

    private void OpenDetailDialog(CustomerSummary customer)
    {
        _detailCustomer      = customer;
        _detailStub          = BuildDetailStub(customer);
        _detailDialogVisible = true;
    }

    private void CloseDetailDialog()
    {
        _detailDialogVisible = false;
        _detailCustomer      = null;
    }

    /// <summary>
    /// Builds stub supplementary data for the detail dialog.
    /// Replace with real API calls once the admin GetCustomerDetail RPC is available.
    /// </summary>
    private static CustomerDetailStub BuildDetailStub(CustomerSummary customer)
    {
        // Derive seed from account id for deterministic stub values.
        var seed = Math.Abs(customer.AccountId.GetHashCode());
        var rng  = new Random(seed);

        // Stub email and ID derived from phone to appear plausible.
        var phoneDigits = new string(customer.PhoneNumber.Where(char.IsDigit).ToArray());
        var emailUser   = customer.FullName.ToLowerInvariant()
                              .Replace(" ", ".")
                              .Replace("'", "");

        return new CustomerDetailStub
        {
            Email               = $"{emailUser}@customers.goldbank.zw",
            IdNumber            = $"ZW-NID-{phoneDigits[^6..]}",
            ZwgBalance          = Math.Round(rng.NextDouble() * 50_000, 2),
            UsdBalance          = Math.Round(rng.NextDouble() * 5_000,  2),
            ActiveDisputesCount = rng.Next(0, 3),
            ActiveLoansCount    = rng.Next(0, 2),
            RecentTransactions  =
            [
                new StubTransaction
                {
                    Date        = DateTime.UtcNow.AddDays(-1),
                    Description = "Mobile Money Transfer",
                    Amount      = 1_200m,
                    Currency    = "ZWG",
                    IsDebit     = true,
                },
                new StubTransaction
                {
                    Date        = DateTime.UtcNow.AddDays(-2),
                    Description = "Salary Credit",
                    Amount      = 18_500m,
                    Currency    = "ZWG",
                    IsDebit     = false,
                },
                new StubTransaction
                {
                    Date        = DateTime.UtcNow.AddDays(-3),
                    Description = "ZESA Utility Payment",
                    Amount      = 450m,
                    Currency    = "ZWG",
                    IsDebit     = true,
                },
                new StubTransaction
                {
                    Date        = DateTime.UtcNow.AddDays(-5),
                    Description = "USD Wallet Top-Up",
                    Amount      = 200m,
                    Currency    = "USD",
                    IsDebit     = false,
                },
                new StubTransaction
                {
                    Date        = DateTime.UtcNow.AddDays(-7),
                    Description = "Loan Repayment",
                    Amount      = 430m,
                    Currency    = "ZWG",
                    IsDebit     = true,
                },
            ],
        };
    }

    private static Color GetKycColor(int kycLevel) => kycLevel switch
    {
        >= 3 => Color.Success,
        2    => Color.Warning,
        1    => Color.Info,
        _    => Color.Default,
    };

    // ── Stub models for detail dialog ────────────────────────────────────────

    private sealed class CustomerDetailStub
    {
        public string? Email              { get; init; }
        public string? IdNumber           { get; init; }
        public double  ZwgBalance         { get; init; }
        public double  UsdBalance         { get; init; }
        public int     ActiveDisputesCount { get; init; }
        public int     ActiveLoansCount    { get; init; }
        public List<StubTransaction> RecentTransactions { get; init; } = [];
    }

    private sealed class StubTransaction
    {
        public DateTime Date        { get; init; }
        public string   Description { get; init; } = string.Empty;
        public decimal  Amount      { get; init; }
        public string   Currency    { get; init; } = "ZWG";
        public bool     IsDebit     { get; init; }
    }
}
