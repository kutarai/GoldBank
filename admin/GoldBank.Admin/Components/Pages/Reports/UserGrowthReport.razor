@page "/reports/users"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = AdminRoles.ReportAccess)]
@inject ReportingService.ReportingServiceClient ReportingClient
@inject ISnackbar Snackbar

<PageTitle>User Growth Report</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">User Growth Report</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudDateRangePicker @bind-DateRange="_dateRange"
                                Label="Date Range"
                                Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect @bind-Value="_granularity"
                       Label="Granularity"
                       Variant="Variant.Outlined">
                <MudSelectItem Value="@("Daily")">Daily</MudSelectItem>
                <MudSelectItem Value="@("Weekly")">Weekly</MudSelectItem>
                <MudSelectItem Value="@("Monthly")">Monthly</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="GenerateReportAsync"
                       Disabled="_loading"
                       StartIcon="@Icons.Material.Filled.Assessment">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Generating...</span>
                }
                else
                {
                    <span>Generate</span>
                }
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_response is not null)
{
    <MudGrid Class="mb-4">
        <MudItem xs="12" md="4">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Total Registered</MudText>
                    <MudText Typo="Typo.h5">@_response.TotalRegistered.ToString("N0")</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Total Active</MudText>
                    <MudText Typo="Typo.h5">@_response.TotalActive.ToString("N0")</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Growth Rate</MudText>
                    <MudText Typo="Typo.h5">@_response.GrowthRate</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @if (_chartLabels.Length > 0)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">User Growth Over Time</MudText>
            <MudChart ChartType="ChartType.Line"
                      ChartSeries="_chartSeries"
                      XAxisLabels="_chartLabels"
                      Width="100%"
                      Height="350px" />
        </MudPaper>
    }

    <MudPaper Class="pa-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-2">Data Points</MudText>
        <MudTable Items="_response.DataPoints" Dense="true" Hover="true" Striped="true" Bordered="true">
            <HeaderContent>
                <MudTh>Period</MudTh>
                <MudTh>New Registrations</MudTh>
                <MudTh>Active Users</MudTh>
                <MudTh>Churned Users</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Period">@context.Period</MudTd>
                <MudTd DataLabel="New Registrations">@context.NewRegistrations.ToString("N0")</MudTd>
                <MudTd DataLabel="Active Users">@context.ActiveUsers.ToString("N0")</MudTd>
                <MudTd DataLabel="Churned Users">@context.ChurnedUsers.ToString("N0")</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    private MudBlazor.DateRange? _dateRange = new(DateTime.Now.AddMonths(-1), DateTime.Now);
    private string _granularity = "Daily";
    private bool _loading;
    private UserGrowthResponse? _response;
    private List<ChartSeries> _chartSeries = [];
    private string[] _chartLabels = [];

    private async Task GenerateReportAsync()
    {
        if (_dateRange?.Start is null || _dateRange?.End is null)
        {
            Snackbar.Add("Please select a valid date range.", Severity.Warning);
            return;
        }

        _loading = true;

        try
        {
            var request = new UserGrowthRequest
            {
                DateRange = new GoldBank.Protos.Common.DateRange
                {
                    From = Timestamp.FromDateTime(_dateRange.Start.Value.ToUniversalTime()),
                    To = Timestamp.FromDateTime(_dateRange.End.Value.ToUniversalTime())
                },
                Granularity = _granularity
            };

            _response = await ReportingClient.GetUserGrowthReportAsync(request);
            BuildChartData();
            Snackbar.Add("Report generated successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to generate report: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildChartData()
    {
        if (_response is null || _response.DataPoints.Count == 0)
        {
            _chartLabels = [];
            _chartSeries = [];
            return;
        }

        _chartLabels = _response.DataPoints.Select(dp => dp.Period).ToArray();

        _chartSeries =
        [
            new ChartSeries { Name = "New Registrations", Data = _response.DataPoints.Select(dp => (double)dp.NewRegistrations).ToArray() },
            new ChartSeries { Name = "Active Users", Data = _response.DataPoints.Select(dp => (double)dp.ActiveUsers).ToArray() },
            new ChartSeries { Name = "Churned Users", Data = _response.DataPoints.Select(dp => (double)dp.ChurnedUsers).ToArray() }
        ];
    }
}
